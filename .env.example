NEXT_PUBLIC_APP_URL=https://getvib.fr

# Supabase — client (exposé au navigateur)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — serveur uniquement (NE JAMAIS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=

# Secret partagé entre le cron GitHub Actions et /api/cron/reveal-addresses
CRON_SECRET=

# E-mail (Resend) — notifications admin (ex. demandes de vérification de profil)
# Si RESEND_API_KEY est vide, les e-mails ne sont pas envoyés (la demande reste
# enregistrée en base pour le futur dashboard admin).
RESEND_API_KEY=
# EMAIL_FROM : tant que le domaine getvib.fr n'est pas vérifié dans Resend,
# garder onboarding@resend.dev. Une fois le domaine vérifié → "GetVib <notif@getvib.fr>".
EMAIL_FROM="GetVib <onboarding@resend.dev>"
# Destinataire de toutes les notifs admin (réclamations, vérifications, signalements).
ADMIN_EMAIL=jonathan@getvib.fr

# E-mails admin (séparés par des virgules) ayant accès au back-office /admin
ADMIN_EMAILS="ton-email@exemple.com"

# Double mot de passe pour déverrouiller le back-office /admin
ADMIN_PASSWORD_1="change-moi-1"
ADMIN_PASSWORD_2="change-moi-2"
